2026-04-02T15:52:04.8789579Z [36;1m    dur = f'{durations[i-1]:.1f}s' if i <= len(durations) else '?'[0m
2026-04-02T15:52:04.8789952Z [36;1m    print(f'  {name}: {dur}, dns:{hits}h/{misses}m')[0m
2026-04-02T15:52:04.8790230Z [36;1m[0m
2026-04-02T15:52:04.8790400Z [36;1mif len(durations) >= 2:[0m
2026-04-02T15:52:04.8790831Z [36;1m    print(f'  Speedup: {durations[0]/durations[1]:.1f}x' if durations[1] > 0 else '  2nd domain was instant')[0m
2026-04-02T15:52:04.8791284Z [36;1m" || true[0m
