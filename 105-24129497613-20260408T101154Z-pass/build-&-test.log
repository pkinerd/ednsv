2026-04-08T10:08:10.6650544Z [36;1m    dur = f'{durations[i-1]:.1f}s' if i <= len(durations) else '?'[0m
2026-04-08T10:08:10.6650674Z [36;1m    print(f'  {name}: {dur}, dns:{hits}h/{misses}m')[0m
