2026-05-04T00:26:21.0877049Z [36;1mdotnet run --project src/Ednsv.Cli --configuration Release -- \[0m
2026-05-04T00:26:21.0877148Z [36;1m  google.com gmail.com --verbose \[0m
2026-05-04T00:26:21.0877273Z [36;1m  > "test-output/multi-domain.txt" 2>&1 || true[0m
2026-05-04T00:26:21.0877376Z [36;1mcat "test-output/multi-domain.txt"[0m
2026-05-04T00:26:21.0877443Z [36;1m[0m
2026-05-04T00:26:21.0877512Z [36;1mecho ""[0m
2026-05-04T00:26:21.0877660Z [36;1mecho "============================================"[0m
2026-05-04T00:26:21.0877769Z [36;1mecho "Per-domain cache reuse analysis:"[0m
2026-05-04T00:26:21.0877865Z [36;1mecho "============================================"[0m
2026-05-04T00:26:21.0877942Z [36;1mpython3 -c "[0m
2026-05-04T00:26:21.0878028Z [36;1mimport re[0m
2026-05-04T00:26:21.0878093Z [36;1m[0m
2026-05-04T00:26:21.0878179Z [36;1m# Strip ANSI escape codes[0m
2026-05-04T00:26:21.0878318Z [36;1mraw = open('test-output/multi-domain.txt').read()[0m
2026-05-04T00:26:21.0878421Z [36;1mtext = re.sub(r'\x1b\[[0-9;]*m', '', raw)[0m
2026-05-04T00:26:21.0878484Z [36;1m[0m
2026-05-04T00:26:21.0878624Z [36;1m# Duration is in Spectre table: │ Duration │ 80.7s │[0m
2026-05-04T00:26:21.0878863Z [36;1mdurations = [float(m.group(1)) for m in re.finditer(r'Duration\s*│\s*(\d+\.?\d*)s', text)][0m
2026-05-04T00:26:21.0878936Z [36;1m[0m
2026-05-04T00:26:21.0879113Z [36;1m# Find DNS hit/miss totals per domain block (split on Validating:)[0m
2026-05-04T00:26:21.0879225Z [36;1mblocks = re.split(r'Validating:', text)[0m
2026-05-04T00:26:21.0879328Z [36;1mdomains = ['google.com', 'gmail.com'][0m
2026-05-04T00:26:21.0879437Z [36;1mfor i, block in enumerate(blocks[1:], 1):[0m
2026-05-04T00:26:21.0879554Z [36;1m    hm = re.findall(r'dns:(\d+)h/(\d+)m', block)[0m
2026-05-04T00:26:21.0879647Z [36;1m    hits = sum(int(h) for h,_ in hm)[0m
2026-05-04T00:26:21.0879746Z [36;1m    misses = sum(int(m) for _,m in hm)[0m
2026-05-04T00:26:21.0879902Z [36;1m    name = domains[i-1] if i <= len(domains) else f'domain #{i}'[0m
2026-05-04T00:26:21.0880052Z [36;1m    dur = f'{durations[i-1]:.1f}s' if i <= len(durations) else '?'[0m
2026-05-04T00:26:21.0880175Z [36;1m    print(f'  {name}: {dur}, dns:{hits}h/{misses}m')[0m
2026-05-04T00:26:21.0880244Z [36;1m[0m
2026-05-04T00:26:21.0880331Z [36;1mif len(durations) >= 2:[0m
2026-05-04T00:26:21.0880611Z [36;1m    print(f'  Speedup: {durations[0]/durations[1]:.1f}x' if durations[1] > 0 else '  2nd domain was instant')[0m
2026-05-04T00:26:21.0880690Z [36;1m" || true[0m
