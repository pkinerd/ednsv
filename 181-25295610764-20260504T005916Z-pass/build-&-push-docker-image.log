2026-05-04T00:45:44.8057782Z           "commits": [
2026-05-04T00:45:44.8058090Z             {
2026-05-04T00:45:44.8059814Z               "author": {
2026-05-04T00:45:44.8060227Z                 "email": "noreply@anthropic.com",
2026-05-04T00:45:44.8060649Z                 "name": "Claude",
2026-05-04T00:45:44.8061049Z                 "username": "claude"
2026-05-04T00:45:44.8061428Z               },
2026-05-04T00:45:44.8061737Z               "committer": {
2026-05-04T00:45:44.8062132Z                 "email": "noreply@anthropic.com",
2026-05-04T00:45:44.8062573Z                 "name": "Claude",
2026-05-04T00:45:44.8062945Z                 "username": "claude"
2026-05-04T00:45:44.8063562Z               },
2026-05-04T00:45:44.8063865Z               "distinct": false,
2026-05-04T00:45:44.8064288Z               "id": "bbe390a32367e80f91ff50a6beca8a62f82d82a2",
2026-05-04T00:45:44.8067667Z               "message": "Fix DKIM defaults stuck on \"loading\" and suppress browser translate offer\n\nAn empty saved dkimSelectors array ([]) from localStorage was setting\ndkimUserCustomized=true even though the field was blank, blocking the\n/api/defaults response from populating it. Guard the flag so it only\nfires when the saved list is non-empty.\n\nAdd translate=\"no\" to all pages so Chrome/Edge don't offer to translate;\nthe DNS record content confuses browser language detectors.\n\nhttps://claude.ai/code/session_01HQsfAXid9F8X7vcjWgbkK1",
2026-05-04T00:45:44.8071162Z               "timestamp": "2026-05-03T23:57:12Z",
2026-05-04T00:45:44.8071721Z               "tree_id": "7b87c560bd508ef92bb022011bed3b105cbfb462",
2026-05-04T00:45:44.8072558Z               "url": "https://github.com/pkinerd/ednsv/commit/bbe390a32367e80f91ff50a6beca8a62f82d82a2"
2026-05-04T00:45:44.8073273Z             },
2026-05-04T00:45:44.8073571Z             {
2026-05-04T00:45:44.8073885Z               "author": {
2026-05-04T00:45:44.8074253Z                 "email": "noreply@anthropic.com",
2026-05-04T00:45:44.8074724Z                 "name": "Claude",
2026-05-04T00:45:44.8075073Z                 "username": "claude"
2026-05-04T00:45:44.8075642Z               },
2026-05-04T00:45:44.8075924Z               "committer": {
2026-05-04T00:45:44.8076353Z                 "email": "noreply@anthropic.com",
2026-05-04T00:45:44.8076822Z                 "name": "Claude",
2026-05-04T00:45:44.8077251Z                 "username": "claude"
2026-05-04T00:45:44.8077687Z               },
2026-05-04T00:45:44.8078015Z               "distinct": false,
2026-05-04T00:45:44.8078588Z               "id": "ee88f065c91768538ce578876079963266e41ffd",
2026-05-04T00:45:44.8081255Z               "message": "Route sync /api/validate trace through ILogger<Program>\n\nThe sync endpoint logged trace output via app.Logger, whose category\nsits under Microsoft.AspNetCore.* and is intentionally clamped to\nWarning by run-web.sh. That filtered out --trace's Debug messages\nbefore any formatter saw them. Inject ILogger<Program> and use it for\nboth the request scope and the trace lambda so the Program=Debug\noverride from --trace takes effect; the async path already worked.\n\nhttps://claude.ai/code/session_01HQsfAXid9F8X7vcjWgbkK1",
2026-05-04T00:45:44.8083066Z               "timestamp": "2026-05-04T00:08:27Z",
2026-05-04T00:45:44.8083381Z               "tree_id": "1dcd6ca925f41879f38a6ca1e724e080ba60eb49",
2026-05-04T00:45:44.8083824Z               "url": "https://github.com/pkinerd/ednsv/commit/ee88f065c91768538ce578876079963266e41ffd"
2026-05-04T00:45:44.8084217Z             },
2026-05-04T00:45:44.8084374Z             {
2026-05-04T00:45:44.8084554Z               "author": {
2026-05-04T00:45:44.8084775Z                 "email": "noreply@anthropic.com",
2026-05-04T00:45:44.8085024Z                 "name": "Claude",
2026-05-04T00:45:44.8085245Z                 "username": "claude"
2026-05-04T00:45:44.8085449Z               },
2026-05-04T00:45:44.8085626Z               "committer": {
2026-05-04T00:45:44.8085846Z                 "email": "noreply@anthropic.com",
2026-05-04T00:45:44.8086094Z                 "name": "Claude",
2026-05-04T00:45:44.8086301Z                 "username": "claude"
2026-05-04T00:45:44.8086518Z               },
2026-05-04T00:45:44.8086690Z               "distinct": false,
2026-05-04T00:45:44.8086949Z               "id": "25dff71ab69177730ab8414d52db288376c98732",
2026-05-04T00:45:44.8089794Z               "message": "Actually enable trace output and fix Dictionary scope rendering\n\nrun-web.sh --trace raised log levels but never set the Trace config\nflag, so validator.Trace was never attached and no Debug messages\nwere ever emitted. Export Trace=True alongside the log-level overrides.\n\nSwitch every BeginScope(new Dictionary<...>) to the formatted-string\noverload. The JSON formatter writes scope.ToString() into the Message\nfield; Dictionary's ToString returns its type name\n(System.Collections.Generic.Dictionary`2[...]). FormattedLogValues\nrenders the rendered message instead while still exposing the same\nnamed fields in the structured output.\n\nhttps://claude.ai/code/session_01HQsfAXid9F8X7vcjWgbkK1",
2026-05-04T00:45:44.8092446Z               "timestamp": "2026-05-04T00:15:14Z",
2026-05-04T00:45:44.8092740Z               "tree_id": "cb6759195184d604d03f847f2f473d890913a379",
2026-05-04T00:45:44.8093197Z               "url": "https://github.com/pkinerd/ednsv/commit/25dff71ab69177730ab8414d52db288376c98732"
2026-05-04T00:45:44.8093577Z             },
2026-05-04T00:45:44.8093751Z             {
2026-05-04T00:45:44.8093915Z               "author": {
2026-05-04T00:45:44.8094142Z                 "email": "noreply@anthropic.com",
2026-05-04T00:45:44.8094394Z                 "name": "Claude",
2026-05-04T00:45:44.8094611Z                 "username": "claude"
2026-05-04T00:45:44.8094827Z               },
2026-05-04T00:45:44.8094999Z               "committer": {
2026-05-04T00:45:44.8095240Z                 "email": "noreply@anthropic.com",
2026-05-04T00:45:44.8095490Z                 "name": "Claude",
2026-05-04T00:45:44.8095715Z                 "username": "claude"
2026-05-04T00:45:44.8095919Z               },
2026-05-04T00:45:44.8096101Z               "distinct": false,
2026-05-04T00:45:44.8096432Z               "id": "feeee34b657ab53b1cc18c58104ba43f57c71fa0",
2026-05-04T00:45:44.8098753Z               "message": "Strip {OriginalFormat} and scope Message from JSON log output\n\nReplace AddJsonConsole with a custom CleanJsonFormatter that emits\nstructured properties only: {OriginalFormat} template strings and the\nredundant State.Message / Scope.Message fields are excluded, leaving\na flat graph of typed values that can be filtered directly with jq.\n\nAlso requires Microsoft.Extensions.Logging.Console to be referenced\ndirectly (LogEntry<TState> lives in the .Abstractions namespace, not\nthe global-using-imported .Logging namespace).\n\nhttps://claude.ai/code/session_01HQsfAXid9F8X7vcjWgbkK1",
2026-05-04T00:45:44.8102014Z               "timestamp": "2026-05-04T00:32:28Z",
2026-05-04T00:45:44.8102508Z               "tree_id": "751359c462fd5e69bf2209edaaf9d6c0b4b49be3",
2026-05-04T00:45:44.8103283Z               "url": "https://github.com/pkinerd/ednsv/commit/feeee34b657ab53b1cc18c58104ba43f57c71fa0"
2026-05-04T00:45:44.8104030Z             },
